---
layout: none
---

{% assign folders = site.static_files | map: "path" | join: "," | split: "/assets/" %}
{% assign folders = folders | map: "split: '/'" | map: "first" | uniq %}

[
{% for f in folders %}
{
  "folder":"{{ f }}",
  "title":"assets/{{ f }}/title.txt",
  "description":"assets/{{ f }}/desc.txt",
  "date":"assets/{{ f }}/date.txt",
  "image":"assets/{{ f }}/img.png"
}{% unless forloop.last %},{% endunless %}
{% endfor %}
]
