---
layout: none
---

{% assign folders = "" | split: "" %}

{% for file in site.static_files %}
  {% if file.path contains "/assets/" %}
    {% assign parts = file.path | split: "/" %}
    {% assign folder = parts[2] %}
    {% unless folders contains folder %}
      {% assign folders = folders | push: folder %}
    {% endunless %}
  {% endif %}
{% endfor %}

[
{% for folder in folders %}
{
  "folder": "{{ folder }}",
  "title": "assets/{{ folder }}/title.txt",
  "description": "assets/{{ folder }}/desc.txt",
  "date": "assets/{{ folder }}/date.txt",
  "image": "assets/{{ folder }}/img.png"
}{% unless forloop.last %},{% endunless %}
{% endfor %}
]
